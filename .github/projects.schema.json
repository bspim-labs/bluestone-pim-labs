{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["name", "description", "github", "status"],
    "additionalProperties": false,
    "properties": {
      "name": { "type": "string", "minLength": 1 },
      "description": { "type": "string", "minLength": 1 },
      "url": { "type": "string", "pattern": "^https://" },
      "github": { "type": "string", "pattern": "^https://github\\.com/", "minLength": 1 },
      "status": { "type": "string", "enum": ["live", "beta", "wip", "archived"] },
      "cta": { "type": "string", "minLength": 1 },
      "icon": { "type": "string", "enum": ["terminal", "template", "default"] }
    }
  }
}
